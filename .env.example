TARGET_SYMBOLS=XAUUSD,XAGUSD,EURUSD,USDJPY
# 券商品种映射（可选）：内部仍用标准名，发给 MT5 时转换为券商实际品种名
# 示例：{"XAUUSD":"GOLD","XAGUSD":"SILVER","EURUSD":"EURUSDm"}
BROKER_SYMBOL_MAP_JSON=
REFRESH_INTERVAL_SEC=30
# 点差阈值覆盖（可选）：按品种族动态调整 warn/alert 点差和百分比
# 示例：{"XAU":{"warn_points":55,"alert_points":85,"warn_pct":0.02,"alert_pct":0.035},"XAG":{"warn_points":90,"alert_points":130,"warn_pct":0.045,"alert_pct":0.07},"FX":{"warn_points":30,"alert_points":45,"warn_pct":0.022,"alert_pct":0.04}}
QUOTE_RISK_THRESHOLDS_JSON=
EVENT_RISK_MODE=normal
EVENT_AUTO_MODE_ENABLED=0
EVENT_SCHEDULES=
EVENT_PRE_WINDOW_MIN=30
EVENT_POST_WINDOW_MIN=15
EVENT_FEED_ENABLED=0
EVENT_FEED_URL=
EVENT_FEED_REFRESH_MIN=60
MACRO_NEWS_FEED_ENABLED=0
MACRO_NEWS_FEED_URLS=
MACRO_NEWS_FEED_REFRESH_MIN=30
MACRO_DATA_FEED_ENABLED=0
# 宏观数据源规格：填入 JSON 数组或本地 JSON 文件路径（如 knowledge_docs/macro_specs.json）
# 默认官方配置已内置于 macro_data_sources.official.json（fred/bls/treasury/yfinance/alphavantage）
MACRO_DATA_FEED_SPECS=
MACRO_DATA_FEED_REFRESH_MIN=60
# Alpha Vantage API Key (免费申请: https://www.alphavantage.co/support/#api-key)
# 用于拉取 CPI / NFP 月频数据
ALPHAVANTAGE_API_KEY=
# FRED API Key (免费申请: https://fred.stlouisfed.org/docs/api/api_key.html)
# 用于拉取 10年期实际利率 / 联邦基金利率等权威数据
FRED_API_KEY=
# BLS API Key (可选，不填则使用公开接口，有频率限制)
BLS_API_KEY=
LEARNING_PUSH_ENABLED=0
LEARNING_PUSH_MIN_INTERVAL_HOUR=12
NOTIFY_DND_ENABLED=1
NOTIFY_DND_START_HOUR=0
NOTIFY_DND_END_HOUR=7
OVERNIGHT_SPREAD_GUARD_ENABLED=1
OVERNIGHT_SPREAD_GUARD_START_HOUR=5
OVERNIGHT_SPREAD_GUARD_END_HOUR=7
MT5_PATH=
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
DINGTALK_WEBHOOK=
PUSHPLUS_TOKEN=
NOTIFY_COOLDOWN_MIN=30
AI_API_KEY=
AI_API_BASE=https://api.siliconflow.cn/v1
AI_MODEL=deepseek-ai/DeepSeek-R1
AI_PUSH_ENABLED=0
AI_PUSH_SUMMARY_ONLY=1
# 自动 AI 研判间隔，0 表示关闭自动研判
AI_AUTO_INTERVAL_MIN=0
# 交易模式：simulation=模拟盘；live=实盘。实盘会直接向 MT5 发单，默认必须保持 simulation
TRADE_MODE=simulation
# 实盘日内最大亏损熔断比例，仅 TRADE_MODE=live 时使用
LIVE_MAX_DRAWDOWN_PCT=0.05
# 实盘预检模式：1=只做 order_check 不真实发单；0=允许 order_send
LIVE_ORDER_PRECHECK_ONLY=1
# 实盘最大同时持仓数，达到上限后禁止继续开仓
LIVE_MAX_OPEN_POSITIONS=1
# 实盘每日最多 AI 订单数，达到上限后禁止继续开仓
LIVE_MAX_ORDERS_PER_DAY=3
# 模拟盘起始本金（建议新手使用 100 / 1000）
SIM_INITIAL_BALANCE=1000
# 无第二目标位时，浮盈达到多少 R 后触发短线保本保护
SIM_NO_TP2_LOCK_R=0.5
# 无第二目标位时，首次锁盈减仓比例（0.10 ~ 0.90）
SIM_NO_TP2_PARTIAL_CLOSE_RATIO=0.5
# 自动试仓基础 RR 门槛
SIM_MIN_RR=1.6
# 本地模型胜率较高时允许放宽到的 RR 门槛
SIM_RELAXED_RR=1.3
# 本地模型允许放宽 RR 前要求的最低胜率
SIM_MODEL_MIN_PROBABILITY=0.68
# 按策略族独立设置探索试仓最小 RR，HITL 批准策略学习建议后会更新对应策略
SIM_STRATEGY_MIN_RR_JSON={"early_momentum":1.3,"direct_momentum":1.4,"pullback_sniper_probe":1.45,"directional_probe":1.8}
# 按策略族独立设置探索试仓日上限，未命中策略族时仍回退到全局 SIM_EXPLORATORY_DAILY_LIMIT
SIM_STRATEGY_DAILY_LIMIT_JSON={"early_momentum":3,"direct_momentum":3,"pullback_sniper_probe":3,"directional_probe":3}
# 模拟盘探索试仓每日上限；0 表示不限制
SIM_EXPLORATORY_DAILY_LIMIT=3
# 按策略族独立设置探索试仓冷却分钟数，未命中策略族时仍回退到全局 SIM_EXPLORATORY_COOLDOWN_MIN
SIM_STRATEGY_COOLDOWN_JSON={"early_momentum":10,"direct_momentum":10,"pullback_sniper_probe":10,"directional_probe":10}
# 同一品种同一方向探索试仓冷却分钟数；0 表示不限制
SIM_EXPLORATORY_COOLDOWN_MIN=10
